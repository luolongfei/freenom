{
    "name": "luolongfei/freenom",
    "description": "freenom域名自动续期。",
    "type": "project",
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-openssl": "*",
        "guzzlehttp/guzzle": "^7.10",
        "monolog/monolog": "^3.10",
        "bramus/monolog-colored-line-formatter": "^3.1.2",
        "phpmailer/phpmailer": "^7.0.2",
        "vlucas/phpdotenv": "^5.6.3",
        "predis/predis": "^3.4.2",
        "ext-json": "*",
        "ext-bcmath": "*",
        "ext-pdo": "*",
        "kevinlebrun/colors.php": "^1.0",
        "ext-mbstring": "*"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "luolongfei",
            "email": "luolongf@gmail.com",
            "homepage": "https://github.com/luolongfei/freenom"
        }
    ],
    "autoload": {
        "psr-4": {
            "Luolongfei\\Libs\\": "libs",
            "Luolongfei\\App\\": "app"
        },
        "files": [
            "app/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Luolongfei\\Tests\\": "tests"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "scripts": {
        "test": "@php -d xdebug.mode=off vendor/bin/phpunit --colors=always"
    },
    "config": {
        "platform-check": false
    }
}
